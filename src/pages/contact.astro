---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Contact"
    title="Let's build something together."
    subtitle="Have a project in mind, want to discuss an architecture problem, or just want to connect? Fill in the form and I'll get back to you within 24 hours."
  />

  <ContactUs
    id="form"
    title="Send a message"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'Tell me about your project or question',
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to the collection of your personal information for the purpose of responding to your enquiry.',
    }}
    description="I typically respond within 24 hours."
  />

  <!-- Contact Details *************** -->

  <Features2
    title="Other ways to reach me"
    items={[
      {
        title: 'GitHub',
        description: 'Browse my open-source work and project source code.',
        icon: 'tabler:brand-github',
      },
      {
        title: 'LinkedIn',
        description: 'Connect with me professionally.',
        icon: 'tabler:brand-linkedin',
      },
      {
        title: 'Email',
        description: 'm.abaeiani@gmail.com',
        icon: 'tabler:mail',
      },
    ]}
  />
</Layout>
