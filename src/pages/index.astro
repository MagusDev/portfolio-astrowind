---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Architecting Intelligent Systems — AI, Cloud & Full-Stack',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'View Case Studies',
        href: '#case-studies',
        icon: 'tabler:arrow-right',
      },
      { text: 'Explore The Lab', href: '/blog' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Intelligent Systems Architecture' }}
  >
    <Fragment slot="title">
      Architecting the Next Generation of
      <span class="text-accent dark:text-white"> Intelligent Systems.</span>
    </Fragment>

    <Fragment slot="subtitle">
      I bridge the gap between autonomous Agentic AI workflows, scalable cloud infrastructure, and high-performance
      interactive interfaces.
    </Fragment>
  </Hero>

  <!-- Features Widget — Service Pillars *** -->

  <Features
    id="features"
    tagline="Expertise"
    title="Three Pillars of Practice"
    subtitle="End-to-end ownership — from LLM orchestration and cloud infrastructure to production-grade interactive web."
    items={[
      {
        title: 'Agentic AI & Orchestration',
        description:
          'Designing autonomous, multi-agent workflows (Microsoft AutoGen, LangGraph) and high-performance RAG systems that automate complex research and business logic.',
        icon: 'tabler:brain',
      },
      {
        title: 'Cloud & Distributed Infrastructure',
        description:
          'Engineering resilient, zero-downtime backend architectures using Kubernetes, Docker, and Kafka to handle high-frequency data and heavy LLM workloads.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Spatial & Full-Stack Web',
        description:
          'Delivering production-grade, immersive user experiences utilizing Next.js, Postgres, and WebGL/Three.js to make complex AI systems accessible and visually engaging.',
        icon: 'tabler:cube-3d-sphere',
      },
    ]}
  />

  <!-- Case Studies ****************** -->

  <Content
    id="case-studies"
    isReversed
    tagline="Case Study 01"
    title="UBICOMP Multi-Agent Ecosystem"
    items={[
      {
        title: 'Dynamic Skill-Loading Architecture',
        description:
          'Built a runtime skill-loading system allowing agents to hot-swap capabilities without redeployment — enabling continuous autonomous evolution of the swarm.',
      },
      {
        title: 'System-Wide Observability with OpenLit',
        description:
          'Integrated OpenLit to instrument every LLM call across the ecosystem, capturing latency distributions, token usage, and cost attribution at the agent level.',
      },
      {
        title: 'Stack',
        description: 'Microsoft AutoGen · LangGraph · OpenLit · Python · FastAPI · Redis',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1677442135703-1787eea5ce01?auto=format&fit=crop&w=1200&q=80',
      alt: 'Multi-Agent System Visualization',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Autonomous multi-agent orchestration at scale
      </h3>
      A research-grade ecosystem where autonomous agents dynamically load skills, coordinate tasks, and are fully observable
      from a single telemetry plane.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    tagline="Case Study 02"
    title="Musical Institution ERP (Freelance SaaS)"
    items={[
      {
        title: 'Full DevOps Lifecycle Ownership',
        description:
          'Sole engineer responsible for architecture, development, CI/CD pipeline, and production deployment of a multi-tenant SaaS platform serving music schools.',
      },
      {
        title: 'PgBouncer & MinIO for Production Scale',
        description:
          'Deployed PgBouncer for database connection pooling under heavy concurrent load, and MinIO for highly-available, S3-compatible object storage of student media files.',
      },
      {
        title: 'Stack',
        description: 'Next.js 15 · PostgreSQL · PgBouncer · MinIO · Docker · Nginx',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=1200&q=80',
      alt: 'SaaS ERP Dashboard',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        End-to-end SaaS delivery, zero prior infrastructure
      </h3>
      Took a music school from spreadsheets to a fully managed SaaS ERP — owning every layer from database design to production
      ops.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent
    tagline="Case Study 03"
    title="Distributed SCADA System"
    items={[
      {
        title: 'Message-Driven Microservices with Kafka & MQTT',
        description:
          'Architected a fully event-driven pipeline where MQTT sensors publish to a Kafka broker, decoupling data ingestion from processing and enabling horizontal scaling of consumers.',
      },
      {
        title: 'Kubernetes-Orchestrated Deployment',
        description:
          'Containerized every service and orchestrated on Kubernetes, achieving self-healing deployments, automated rollouts, and resource-isolated workloads for 24/7 uptime.',
      },
      {
        title: 'Stack',
        description: 'Apache Kafka · MQTT · Kubernetes · Docker · Python · TimescaleDB',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1518432031352-d6fc5c10da5a?auto=format&fit=crop&w=1200&q=80',
      alt: 'Distributed SCADA Architecture',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Enterprise-grade data pipelines, IoT to cloud
      </h3>
      Replaced a monolithic SCADA relay with a fully distributed, message-driven microservices architecture capable of handling
      thousands of sensor events per second.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- The Lab — Latest Posts ******* -->

  <BlogLatestPosts
    title="The Lab — Digital Garden"
    information={`Deep-dives, experiments, and build logs across AI, infrastructure, and interactive systems.`}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Get In Touch',
        href: '/contact',
        icon: 'tabler:mail',
      },
    ]}
  >
    <Fragment slot="title">
      Let's build something<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> together.</span>
    </Fragment>

    <Fragment slot="subtitle">
      I am actively looking for opportunities in AI Engineering, Cloud Infrastructure, and Backend Development —
      available full-time from Autumn 2026.
    </Fragment>
  </CallToAction>
</Layout>
